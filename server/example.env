# ── Puertos expuestos al host ──────────────────────────
NGINX_HTTP_PORT=8080
NGINX_HTTPS_PORT=8443
SSH_PORT=2222

# ── SSH – usuario no-root que se creará en el contenedor ─
SSH_USER=sysadmin
# Pon aquí tu clave pública SSH (ed25519 recomendado)
# Ejemplo: ssh-ed25519 AAAA... usuario@host
SSH_AUTHORIZED_KEY=CHANGE_ME_PUT_YOUR_PUBLIC_KEY_HERE
